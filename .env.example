# ── OpenClaw gateway ────────────────────────────────────────────────────────
# Token used by OpenClaw clients to authenticate against this gateway
OPENCLAW_GATEWAY_TOKEN=change-me

# Telegram bot token (from @BotFather) — used by both gateway and codex-proxy
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Local paths for OpenClaw persistent data (config, sessions, workspace files)
OPENCLAW_CONFIG_DIR=./data
OPENCLAW_WORKSPACE_DIR=./data/workspace

# ── Codex proxy ─────────────────────────────────────────────────────────────
# Port the OpenAI-compatible HTTP server listens on
PROXY_PORT=3001

# Full path to the codex binary
CODEX_BIN=/usr/local/bin/codex

# Working directory codex runs in (usually your home or project root)
CODEX_WORKDIR=/home/youruser

# Telegram chat ID that receives command approval requests (your personal chat ID)
TELEGRAM_APPROVAL_CHAT_ID=123456789
